# Copy to .env and fill in. Never commit .env.

# Figma Personal Access Token (Variables API + file read)
# https://www.figma.com/developers/api#access-tokens
FIGMA_ACCESS_TOKEN=

# Figma file key from the design-system file URL:
# https://www.figma.com/design/<FILE_KEY>/...
FIGMA_FILE_KEY=

# Optional: webhook signing secret (Phase 2+)
FIGMA_WEBHOOK_SECRET=

# GitHub (Phase 2+ — PR bot)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_OWNER=
GITHUB_REPO=
